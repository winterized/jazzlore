# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
storybook-static
*.local

# Scratch output dir (icon-preview composites, ad-hoc renders, etc.).
tmp/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Env files
.env
.env.local
.env.*.local
.dev.vars
.dev.vars.*

# Wrangler local state/cache (musicians unified Worker dev) — never commit
.wrangler/

# Test artifacts
coverage/
playwright-report/
test-results/
.playwright/
.playwright-mcp/
baselines/

# Joint-fix acceptance captures — reproducible from
# tests/e2e/musicians-joint-fix-acceptance.spec.ts, can run to tens of MB per
# PNG (the broken-prod CRIT-1 mobile capture is literally 14624 px wide).
# Only the directory marker + README is tracked; the captures are regenerable.
apps/musicians/docs/baseline/joint-fix/**
!apps/musicians/docs/baseline/joint-fix/.gitkeep

# oh-my-claudecode agent session state — transient runtime artifacts the
# plugin writes per session (replay logs, checkpoints, mission/tracking
# JSON). Never relevant in git; were leaking into PR diffs via `git add -A`.
# Scoped narrowly: `.omc/notepads/`, `.omc/sessions/`, and any other
# deliberately-curated content under `.omc/` stay trackable. Issue #51.
**/.omc/state/
**/.omc/checkpoints/
