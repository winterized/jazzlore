{
  "name": "@jazzlore/musicians",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.app.json tsconfig.worker.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b tsconfig.app.json tsconfig.worker.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "dev:worker": "wrangler dev --config ../../wrangler.musicians.jsonc",
    "deploy": "wrangler deploy --config ../../wrangler.musicians.jsonc"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@jazzlore/music-core": "workspace:*",
    "@jazzlore/ui": "workspace:*",
    "d3-force": "^3.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260517.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.92.0"
  }
}
